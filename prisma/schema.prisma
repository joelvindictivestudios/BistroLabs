// BistroLabs datamodell — källa till sanning.
// Vektorkolumner (Unsupported) läses/skrivs via raw SQL i lib/db/vector.ts.
// CLI-anslutning (migrate) konfigureras i prisma.config.ts (DIRECT_URL).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InteractionType {
  EMAIL
  VOICE // v2
  WIDGET // v2
}

enum Intent {
  BOOKING_REQUEST
  BOOKING_MODIFY
  BOOKING_CANCEL
  QUESTION
  COMPLAINT
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SEATED // gästen har checkats in vid bordet
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  RECEIVED
  DRAFT // AI-genererat utkast, väntar på granskning
  SENT // v1 når aldrig hit automatiskt
  ESCALATED // flaggat för människa
}

enum WaitlistStatus {
  WAITING // väntar
  OFFERED // erbjuden — SMS skickat, först till kvarn
}

enum CommLogType {
  RECEIVED // bokning mottagen — systemhändelse utan kanal
  CARD_LINK // kortlänk skickad
  CONFIRMATION // bekräftelse
  REMINDER // påminnelse
  AUTO_CANCELLATION // auto-avbokning vid utebliven kortbekräftelse
  FEE_CHARGED // no-show-avgift debiterad — systemhändelse utan kanal
  CANCELLATION_CONFIRMATION // avbokningsbekräftelse
  CHANGE // ändringsnotis
}

enum CommChannel {
  EMAIL
  SMS
}

model Restaurant {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  /// Supabase Auth user-id (auth.users) — ingen FK eftersom auth-schemat ägs av Supabase
  ownerId   String?  @map("owner_id") @db.Uuid
  /// Opublicerad widget visas bara för ägaren; publikt = "Öppnar snart"
  published Boolean  @default(false)
  /// { timezone, openingHours, bookingDurationMinutes, escalationPartySize,
  ///   confidenceThreshold, tone: { styleGuide, fewShotExamples[] }, menu }
  /// Valideras med zod (RestaurantConfig) i lib/email-concierge/types.ts
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  rooms         Room[]
  tables        DiningTable[]
  guests        Guest[]
  bookings      Booking[]
  threads       EmailThread[]
  knowledgeDocs KnowledgeDocument[]
  waitlist      WaitlistEntry[]

  @@map("restaurants")
}

model Room {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @map("restaurant_id") @db.Uuid
  name         String
  sortOrder    Int           @default(0) @map("sort_order")
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       DiningTable[]

  @@unique([restaurantId, name])
  @@map("rooms")
}

model DiningTable {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  roomId       String?    @map("room_id") @db.Uuid
  name         String
  capacity     Int // max antal gäster
  /// Minsta sällskap som får bordet — "endast 2" = minSeats 2 + capacity 2
  minSeats     Int        @default(1) @map("min_seats")
  shape        String     @default("round") // "round" | "square" | "rect"
  posX         Int        @default(0) @map("pos_x") // rastercell i rummet
  posY         Int        @default(0) @map("pos_y")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  room         Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  bookings     Booking[]

  @@unique([restaurantId, name])
  @@map("tables")
}

model Guest {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  email        String?
  phone        String?
  name         String?
  /// Matgästens Supabase Auth user-id (kind: "guest") — ingen FK, samma skäl som Restaurant.ownerId
  authUserId   String?    @map("auth_user_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  profile      GuestProfile?
  interactions GuestInteraction[]
  bookings     Booking[]
  threads      EmailThread[]

  @@unique([restaurantId, email])
  @@unique([restaurantId, phone])
  @@index([restaurantId, phone])
  @@map("guests")
}

model GuestProfile {
  guestId             String    @id @map("guest_id") @db.Uuid
  preferences         Json      @default("{}")
  /// Övriga upplysningar/allergier — fritext från kundformen (widget/admin)
  notes               String?
  dietaryRestrictions String[]  @map("dietary_restrictions")
  favoriteTable       String?   @map("favorite_table")
  visitCount          Int       @default(0) @map("visit_count")
  avgSpend            Decimal?  @map("avg_spend") @db.Decimal(10, 2)
  lastVisit           DateTime? @map("last_visit")
  /// Opt-in för marknadsföringsutskick (19 § MFL) — transaktionsmejl kräver det inte
  marketingConsent    Boolean   @default(false) @map("marketing_consent")
  marketingConsentAt  DateTime? @map("marketing_consent_at")
  /// Märkningar: "allergi" | "stamgäst" | "barnfamilj"
  tags                String[]  @default([])
  updatedAt           DateTime  @updatedAt @map("updated_at")
  guest               Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("guest_profiles")
}

model GuestInteraction {
  id         String                       @id @default(uuid()) @db.Uuid
  guestId    String                       @map("guest_id") @db.Uuid
  type       InteractionType
  intent     Intent?
  rawContent String                       @map("raw_content")
  summary    String?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now()) @map("created_at")
  guest      Guest                        @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId, createdAt])
  @@map("guest_interactions")
}

model KnowledgeDocument {
  id           String                       @id @default(uuid()) @db.Uuid
  restaurantId String                       @map("restaurant_id") @db.Uuid
  category     String // "faq" | "policy" | "menu"
  title        String
  content      String
  embedding    Unsupported("vector(1536)")?
  createdAt    DateTime                     @default(now()) @map("created_at")
  restaurant   Restaurant                   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, category])
  @@map("knowledge_documents")
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @map("restaurant_id") @db.Uuid
  guestId      String        @map("guest_id") @db.Uuid
  tableId      String?       @map("table_id") @db.Uuid
  startsAt     DateTime      @map("starts_at")
  endsAt       DateTime      @map("ends_at")
  partySize    Int           @map("party_size")
  /// Varav barn — ingår i partySize, info till kök/personal
  childrenCount Int          @default(0) @map("children_count")
  status       BookingStatus @default(PENDING)
  /// När gästen checkades in (status → SEATED) — driver "Sitter · X min"-timern
  seatedAt     DateTime?     @map("seated_at")
  /// Antal som faktiskt kom — default partySize vid incheckning, kan justeras
  arrivedCount Int?          @map("arrived_count")
  notes        String?
  /// Personalens interna anteckning — syns aldrig för gästen
  staffNote    String?       @map("staff_note")
  /// Allergiuppgift från widgeten (GDPR art 9) — GALLRAS (nullas) vid COMPLETED
  allergyNote  String?       @map("allergy_note")
  /// Samtyckeslogg: tidpunkt + exakt formulering gästen godkände (behålls efter gallring)
  allergyConsentAt   DateTime? @map("allergy_consent_at")
  allergyConsentText String?   @map("allergy_consent_text")
  confirmationSentAt DateTime? @map("confirmation_sent_at")
  reminderSentAt     DateTime? @map("reminder_sent_at")
  /// PSP-token för kortgarantin — ALDRIG kortnummer (PCI DSS). Gallras enligt reglerna i jobs/gallring.
  cardPspToken String?       @map("card_psp_token")
  cardLast4    String?       @map("card_last4")
  /// Debiterad no-show-avgift i kr (noShowFeePerGuest × partySize vid debiteringstillfället)
  charged      Decimal?      @db.Decimal(10, 2)
  /// { av: "personal" | "gäst" | "auto", orsak?: string, tidpunkt: ISO-8601 }
  cancelInfo   Json?         @map("cancel_info")
  createdBy    String        @default("concierge") @map("created_by") // "concierge" | "human"
  createdAt    DateTime      @default(now()) @map("created_at")
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest        Guest         @relation(fields: [guestId], references: [id])
  table        DiningTable?  @relation(fields: [tableId], references: [id])
  commLogs     CommunicationLog[]

  @@index([restaurantId, startsAt])
  @@index([tableId, startsAt])
  @@map("bookings")
}

/// Väntelistan (§3.8). Tider i restaurangens LOKALA tid som strängar —
/// matchning sker med zero-paddad strängjämförelse mot Intl-formatterad lokaltid.
model WaitlistEntry {
  id           String         @id @default(uuid()) @db.Uuid
  restaurantId String         @map("restaurant_id") @db.Uuid
  name         String
  phone        String
  partySize    Int            @map("party_size")
  date         String // "YYYY-MM-DD" (lokal dag)
  wishedFrom   String         @map("wished_from") // "HH:MM"
  wishedTo     String         @map("wished_to") // "HH:MM"
  status       WaitlistStatus @default(WAITING)
  offeredTime  String?        @map("offered_time") // "HH:MM" som erbjöds
  offeredAt    DateTime?      @map("offered_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, date, status])
  @@map("waitlist_entries")
}

/// Kommunikationslogg per bokning (§1) — driver tidslinjen "Kommunikation".
/// Rad skrivs endast när ett utskick faktiskt gått ut (eller vid systemhändelse, channel null).
model CommunicationLog {
  id        String       @id @default(uuid()) @db.Uuid
  bookingId String       @map("booking_id") @db.Uuid
  type      CommLogType
  channel   CommChannel? // null = systemhändelse (RECEIVED, FEE_CHARGED)
  /// T.ex. { belopp, chargeId } för FEE_CHARGED; { till } för utskick
  meta      Json?
  sentAt    DateTime     @default(now()) @map("sent_at")
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, sentAt])
  @@map("communication_logs")
}

model EmailThread {
  id           String         @id @default(uuid()) @db.Uuid
  restaurantId String         @map("restaurant_id") @db.Uuid
  guestId      String?        @map("guest_id") @db.Uuid
  subject      String
  createdAt    DateTime       @default(now()) @map("created_at")
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest        Guest?         @relation(fields: [guestId], references: [id])
  messages     EmailMessage[]

  @@index([restaurantId, createdAt])
  @@map("email_threads")
}

model EmailMessage {
  id               String           @id @default(uuid()) @db.Uuid
  threadId         String           @map("thread_id") @db.Uuid
  direction        MessageDirection
  status           MessageStatus    @default(RECEIVED)
  fromAddress      String           @map("from_address")
  body             String
  intent           Intent?
  confidence       Float?
  escalated        Boolean          @default(false)
  escalationReason String?          @map("escalation_reason")
  /// "Jag tar den själv" — personal har tagit över tråden; räknas inte som väntande
  handledAt        DateTime?        @map("handled_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  thread           EmailThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("email_messages")
}
