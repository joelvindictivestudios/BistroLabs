# Kopiera till .env och fyll i värden

# --- Supabase (klient/API) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Supabase Postgres (för Prisma) ---
DATABASE_URL=""
DIRECT_URL=""

# --- OpenAI ---
OPENAI_API_KEY=""
OPENAI_MODEL_CLASSIFIER="gpt-5.4-nano"
OPENAI_MODEL_GENERATOR="gpt-5.4-mini"
OPENAI_MODEL_SUMMARIZER="gpt-5.4-nano"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Twilio (v2 Voice Agent + SMS) ---
TWILIO_ACCOUNT_SID=""
TWILIO_API_KEY_SID=""
TWILIO_API_KEY_SECRET=""
# Fallback-avsändare för SMS när restaurangen saknar eget nummer (E.164)
TWILIO_SMS_FROM=""

# --- Transaktionsmejl (bekräftelse/påminnelse/AI-inkorg) ---
# Utan RESEND_API_KEY loggas utskicken bara (dev-stub)
RESEND_API_KEY=""
EMAIL_FROM="BistroLabs <onboarding@resend.dev>"

# --- Cron-jobb (vercel.json: reminders + gallring + auto-avbokning) ---
CRON_SECRET=""

# --- Gästsjälvservice ---
# HMAC-secret för signerade hanteringslänkar (/hantera/[token]).
# Saknas den utanför produktion används en dev-secret med varning.
BOOKING_LINK_SECRET=""
# Absolut bas-URL för länkar i utskick (annars används anropets origin)
NEXT_PUBLIC_APP_URL=""
